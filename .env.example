# Copy this file to .env.local and fill in your values.

# Meta / Facebook app — get these from developers.facebook.com → your app → Basic Settings.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# Public URL this app is served from. Used for OAuth redirect URIs.
# Must match one of the "Valid OAuth Redirect URIs" configured on the Facebook app.
APP_URL=http://localhost:3000

# Meta Graph API version to target.
META_GRAPH_API_VERSION=v23.0
